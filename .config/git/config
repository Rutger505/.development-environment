  name = Rutger Pronk

[alias]
  s = status
  d = diff
  r = restore

  a = add

  c = commit
  p = push

  u = pull

  sw = switch

[push]
	autoSetupRemote = true
[pull]
	rebase = false
[init]
	defaultBranch = main
[core]
	autocrlf = input
	pager = delta
[interactive]
	diffFilter = delta --color-only
[delta]
	navigate = true
	line-numbers = true
[merge]
	conflictstyle = zdiff3
[diff]
	colorMoved = default
