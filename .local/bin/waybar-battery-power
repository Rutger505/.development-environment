#!/bin/bash
bat=$(upower -e | grep -m1 BAT)
upower -i "$bat" | awk '
  /state:/        { s=$2 }
  /energy-rate:/  { r=int($2) }
  END {
    if (s=="charging")           printf "↑ %dW", r
    else if (s=="discharging")   printf "↓ %dW", r
    else if (s=="fully-charged") printf "󰂅"
    else                         printf "· %dW", r
  }
'
